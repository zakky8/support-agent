{
  "name": "support-agent",
  "version": "1.0.0",
  "description": "Multi-channel AI Support Agent — Website, Telegram & Discord. Built with LangChain-style orchestration, RAG knowledge base, and human handoff.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:web": "tsx watch src/channels/website/server.ts",
    "dev:telegram": "tsx watch src/channels/telegram/bot.ts",
    "dev:discord": "tsx watch src/channels/discord/bot.ts",
    "ingest": "tsx src/knowledge/ingest.ts",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ai-agent",
    "support",
    "customer-service",
    "rag",
    "langchain",
    "telegram-bot",
    "discord-bot",
    "multi-channel"
  ],
  "author": "zakky8",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-ws": "^5.0.2",
    "langchain": "^0.3.15",
    "@langchain/core": "^0.3.30",
    "@langchain/community": "^0.3.25",
    "@langchain/google-genai": "^0.1.9",
    "@langchain/openai": "^0.4.4",
    "telegraf": "^4.16.3",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-ws": "^3.0.5",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
