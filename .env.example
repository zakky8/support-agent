# ──────────────────────────────────────────────────────
# AI Support Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────
# Supported: "google" | "openai"
LLM_PROVIDER=google

# Google Gemini (default)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI (alternative)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Agent Persona ────────────────────────────────────
AGENT_NAME=Atlas
AGENT_COMPANY=YourCompany
AGENT_PERSONA=You are Atlas, an expert AI support agent for YourCompany. You are helpful, empathetic, and professional. You always try to solve the user's problem before escalating. If you don't know the answer, say so honestly and offer to connect them to a human agent.

# ── RAG / Knowledge Base ────────────────────────────
# Directory containing .txt, .md, .pdf knowledge files
KNOWLEDGE_DIR=./knowledge
# Number of relevant chunks to retrieve per query
RAG_TOP_K=5
# Chunk size for document splitting (in characters)
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ── Website Channel ─────────────────────────────────
WEB_ENABLED=true
WEB_PORT=3000
WEB_CORS_ORIGIN=*

# ── Telegram Channel ────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Discord Channel ─────────────────────────────────
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=info
