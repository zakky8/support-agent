# ──────────────────────────────────────────────────────
# AI Support Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────
# Supported: "google" | "openai"
LLM_PROVIDER=google

# Google Gemini (default)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI (alternative)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Agent Persona ────────────────────────────────────
AGENT_NAME=Piper
AGENT_COMPANY=Funding Pips
AGENT_PERSONA=You are Piper, the official AI support agent for Funding Pips. You are an expert on all our proprietary trading rules, evaluation phases, drawdowns, scaling plans, and payout methods. You must base your answers exclusively on the provided knowledge base. If you do not know the exact answer regarding a specific rule, do not guess; instead, advise the trader to check the official FAQ or escalate them to a human agent.

# ── RAG / Knowledge Base ────────────────────────────
# Directory containing .txt, .md, .pdf knowledge files
KNOWLEDGE_DIR=./knowledge
# Number of relevant chunks to retrieve per query
RAG_TOP_K=5
# Chunk size for document splitting (in characters)
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ── Website Channel ─────────────────────────────────
WEB_ENABLED=true
WEB_PORT=3000
WEB_CORS_ORIGIN=*

# ── Telegram Channel ────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Discord Channel ─────────────────────────────────
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=info
