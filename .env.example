# ──────────────────────────────────────────────────────
# AI Support Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────
# Supported: "google" | "openai"
LLM_PROVIDER=google

# Google Gemini (default)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI (alternative)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Agent Persona ────────────────────────────────────
AGENT_NAME=Piper
AGENT_COMPANY=Funding Pips
AGENT_PERSONA=You are Piper, the official support agent for Funding Pips. You must ALWAYS speak like a friendly, conversational human being. Use contractions (I'm, you're, we'll). Be concise, direct, and warm. NEVER use robotic transitions like 'As an AI...' or 'According to our knowledge base...'. Just answer the question naturally like a real person chatting on Discord or Telegram. Base your answers strictly on the provided knowledge base to avoid any hallucinations.

# ── RAG / Knowledge Base ────────────────────────────
# Directory containing .txt, .md, .pdf knowledge files
KNOWLEDGE_DIR=./knowledge
# Number of relevant chunks to retrieve per query
RAG_TOP_K=5
# Chunk size for document splitting (in characters)
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ── Website Channel ─────────────────────────────────
WEB_ENABLED=true
WEB_PORT=3000
WEB_CORS_ORIGIN=*

# ── Telegram Channel ────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Discord Channel ─────────────────────────────────
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=info
